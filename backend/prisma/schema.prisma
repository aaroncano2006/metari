// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  created_at  DateTime? @default(now())
  updated_at  DateTime? @updatedAt
  metas       Meta[]

  @@map("categories")
}

model User {
  id                     Int                      @id @default(autoincrement())
  name                   String //VARCHAR(191) es el valor per defecte  mariadb si no s'especifica
  username               String                   @unique
  email                  String                   @unique
  password               String
  role                   UserRole                 @default(user)
  completed_tasks        BigInt                   @default(0)
  score                  BigInt                   @default(0)
  restore_token          String?                  @db.Text
  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @updatedAt //Actualitza cada vegada que es fa un canvi a la taula
  //Autogenerades relacions  bidireccionals
  groups                 Group[]
  metas                  Meta[]
  assignedAssignations   Assignation[]            @relation("AssignedUser")
  assignerAssignations   Assignation[]            @relation("AssignerUser")
  comments               Comment[]
  proofs                 Proof[]
  sentInvitations        Invitation[] @relation("SentInvitations")
  receivedInvitations    Invitation[] @relation("ReceivedInvitations")
  groupUsers             GroupUser[]
  indexedMetas           IndexedMeta[]
  assignationCompletions AssignationCompletions[]

  //El nom de la taula a la bbdd
  @@map("users")
}

//enum Rol del model User
enum UserRole {
  user
  admin
}

model Group {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?       @db.Text
  owner_id     Int
  is_public    Boolean
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  //referencia al model/taula user
  owner        User          @relation(fields: [owner_id], references: [id])
  //Autogenerades relacions bidireccionals
  metas        Meta[]
  assignations Assignation[]
  invitations  Invitation[]
  groupUsers   GroupUser[]
  // indexedMetas IndexedMeta[]

  @@map("groups")
}

model Meta {
  id          Int     @id @default(autoincrement())
  title       String
  description String? @db.Text
  author_id   Int
  group_id    Int? // no s'utilitza
  category_id Int?

  type         MetaType      @default(task)
  is_public    Boolean       @default(true)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  author       User          @relation(fields: [author_id], references: [id])
  group        Group?        @relation(fields: [group_id], references: [id])
  category     Category?     @relation(fields: [category_id], references: [id])
  //Autogenerades relacions bidireccionals
  assignations Assignation[]
  indexedMetas IndexedMeta[]

  @@map("metas")
}

//enum tipus del model meta
enum MetaType {
  task
  challenge
}

model Assignation {
  id           Int        @id @default(autoincrement())
  group_id     Int?
  meta_id      Int
  user_id      Int?
  assigner_id  Int?
  needs_proofs Boolean?
  start_date   DateTime?  @default(now()) @db.Date
  due_date     DateTime?  @db.Date
  priority     Priority?
  difficulty   Difficulty @default(normal)
  score        BigInt?    @db.UnsignedBigInt
  completed    Boolean    @default(false)
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  group        Group?     @relation(fields: [group_id], references: [id])
  meta         Meta       @relation(fields: [meta_id], references: [id])
  user         User?      @relation("AssignedUser", fields: [user_id], references: [id])
  assigner     User?      @relation("AssignerUser", fields: [assigner_id], references: [id])
  //Autogenerades relacions bidireccionals

  comments               Comment[]
  proofs                 Proof[]
  assignationCompletions AssignationCompletions[]

  @@map("assignations")
}

//enum del model Assignation
enum Priority {
  high
  low
}

//enum del model Assignation
enum Difficulty {
  easy
  normal
  hard
  extreme
}

model Comment {
  id             Int         @id @default(autoincrement())
  assignation_id Int
  user_id        Int
  body           String      @db.Text
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  assignation    Assignation @relation(fields: [assignation_id], references: [id])
  user           User        @relation(fields: [user_id], references: [id])
  //Autogenerades relacions bidireccionals

  @@map("comments")
}

model Proof {
  id             Int         @id @default(autoincrement())
  assignation_id Int
  user_id        Int?
  proof          String      @db.Text
  proof_type     String
  is_valid       Boolean     @default(false)
  created_at     DateTime    @default(now())
  assignation    Assignation @relation(fields: [assignation_id], references: [id])
  user           User?       @relation(fields: [user_id], references: [id])
  //Autogenerades relacions bidireccionals

  @@map("proofs")
}

model Invitation {
  id Int @id @default(autoincrement())

  sender_id   Int
  receiver_id Int
  group_id    Int?
  status      Status   @default(pending)
  created_at  DateTime @default(now())
  group       Group?   @relation(fields: [group_id], references: [id])
  //Dues relacions al mateix model, s'ha d'especificar un nom per cada una de les relacions
  sender      User     @relation("SentInvitations", fields: [sender_id], references: [id])
  receiver    User     @relation("ReceivedInvitations", fields: [receiver_id], references: [id])
  //Autogenerades relacions bidireccionals

  @@unique([sender_id, receiver_id, group_id])
  @@map("invitations")
}

enum Status {
  pending
  accepted
  rejected
}

model GroupUser {
  group_id Int
  user_id  Int
  role     GroupUserRole @default(member)
  group    Group         @relation(fields: [group_id], references: [id])
  user     User          @relation(fields: [user_id], references: [id])
  //Autogenerades relacions bidireccionals

  @@id([group_id, user_id])
  @@map("group_user")
}

enum GroupUserRole {
  member
  moderator
}

model IndexedMeta {
  id                    Int      @id @default(autoincrement())
  user_id               Int? // el que afegeix la meta al grup
  meta_id               Int
  is_approved           Boolean? @default(false)
  is_community_approved Boolean? @default(false)
  user                  User?    @relation(fields: [user_id], references: [id])
  meta                  Meta     @relation(fields: [meta_id], references: [id])
  //group                 Group?   @relation(fields: [group_id], references: [id])

  @@map("index")
}

model AssignationCompletions {
  id             Int     @id @default(autoincrement())
  assignation_id Int
  user_id        Int
  is_Completed   Boolean @default(false)

  user         User        @relation(fields: [user_id], references: [id])
  assignations Assignation @relation(fields: [assignation_id], references: [id])

  @@map("assignation_completions")
}
