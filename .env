# dev || production
ENVIRONMENT="dev"

# === ENV VARIABLES FOR LOCALHOST ===
# Pots deixar-ho buit si només utilitzaràs Docker

# index.js i prisma.config.ts
LOCALHOST=http://localhost
LOCAL_PORT=3001
LOCAL_DATABASE_URL="mysql://root:Naimus@localhost:3307/metari_db"

# ./config/prisma.js
LOCAL_ADAPTER_HOST=localhost
LOCAL_ADAPTER_PORT=3307
LOCAL_ADAPTER_USER=root
LOCAL_ADAPTER_PASSWORD=Naimus
LOCAL_ADAPTER_DATABASE=metari_db

# === ENV VARIABLES FOR DOCKER ===
# Pots deixar-ho buit si només utilitzaràs localhost

# index.js & prisma.config.ts  conection to api
DOCKER_HOST=http://localhost
DOCKER_PORT=3001
DOCKER_DATABASE_URL="mysql://root:root@db:3306/metari_db"

# ./config/prisma.js, conection to db
DOCKER_ADAPTER_HOST=db
DOCKER_ADAPTER_PORT=3306
DOCKER_ADAPTER_USER=root
DOCKER_ADAPTER_PASSWORD=root
DOCKER_ADAPTER_DATABASE=metari_db

# === NODEMAILER CONFIG ===
# La configuració de nodemailer funciona igual tant en desencvolupament local com en Docker

# ./config/nodemailer.js
TRANSPORTER_SERVICE=
TRANSPORTER_USER=
TRANSPORTER_APP_PASS=